# Secrets defined here are available for reference under registry/password,
# env/secret, builder/secrets, and accessories/*/env/secret in config/deploy.yml.
# All secrets should be pulled from a password manager, ENV, or a file.
# DO NOT ENTER RAW CREDENTIALS HERE! This file is safe for git.

# 1Password reference
OP_VAULT="CLI"
OP_ITEM="Engineer"

# Docker Hub Access Token (create at https://hub.docker.com/settings/security).
# The site is fully static, so this is the only secret kamal needs.
KAMAL_REGISTRY_PASSWORD=$(op read "op://${OP_VAULT}/${OP_ITEM}/KAMAL_REGISTRY_PASSWORD")
