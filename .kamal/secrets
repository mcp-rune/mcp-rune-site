# Secrets defined here are available for reference under registry/password,
# env/secret, builder/secrets, and accessories/*/env/secret in config/deploy.yml.
# All secrets should be pulled from a password manager, ENV, or a file.
# DO NOT ENTER RAW CREDENTIALS HERE! This file is safe for git.

# 1Password reference
OP_VAULT="CLI"
OP_ITEM="Production"

# Docker Hub Access Token (create at https://hub.docker.com/settings/security).
KAMAL_REGISTRY_PASSWORD=$(op read "op://${OP_VAULT}/${OP_ITEM}/KAMAL_REGISTRY_PASSWORD")

# Fine-grained PAT scoped to mcp-rune/mcp-rune with Issues: Read-only +
# Metadata: Read-only. Used by `src/pages/roadmap.astro` at build time to
# fetch milestones + tagged issues for the public Roadmap page. Without
# it, /roadmap renders the empty-state design — the site still builds and
# deploys successfully, but the Roadmap shows no cards.
GITHUB_TOKEN=$(op read "op://${OP_VAULT}/${OP_ITEM}/GITHUB_TOKEN")
