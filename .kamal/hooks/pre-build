#!/usr/bin/env bash
# kamal pre-build hook — runs on the host (not inside Docker) right before
# `kamal build`. We rebuild dist/ here so the Dockerfile can just COPY it.
#
# Building outside the image keeps the runtime layer tiny (no Node) and
# resolves the src/content/guides symlink (→ ../mcp-rune/docs/guides) on
# the host, where the target actually exists.

set -euo pipefail

cd "$(dirname "$0")/../.."

echo "==> npm ci (mcp-rune-site)"
npm ci

echo "==> npm run build (Astro static export → dist/)"
npm run build

if [ ! -f dist/index.html ]; then
  echo "ERROR: dist/index.html missing after build — aborting deploy." >&2
  exit 1
fi
