---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopNav from '../components/TopNav.astro';
import Footer from '../components/Footer.astro';
import CliHero from '../components/cli/CliHero.astro';
import CliSellingPoints from '../components/cli/CliSellingPoints.astro';
import CliPresets from '../components/cli/CliPresets.astro';
import CliCtaBand from '../components/cli/CliCtaBand.astro';
---
<BaseLayout
  title="CLI · rune new · mcp-rune"
  description="rune new is the entire CLI. Pick a preset, skip the prompts with --yes, and walk away with a project that boots on the first try."
>
  <TopNav active="cli" />
  <main>
    <CliHero />
    <CliSellingPoints />
    <CliPresets />
    <CliCtaBand />
  </main>
  <Footer />
</BaseLayout>
