---
import DocsLayout from '../../layouts/DocsLayout.astro';
import DocsSidebar from '../../components/DocsSidebar.astro';
import DocsHero from '../../components/docs/DocsHero.astro';
import FeaturedTrio from '../../components/docs/FeaturedTrio.astro';
import SectionBlock from '../../components/docs/SectionBlock.astro';
import ContributionCallout from '../../components/docs/ContributionCallout.astro';
import ExtFlag from '../../components/docs/ExtFlag.astro';
import PlugIcon from '../../components/docs/PlugIcon.astro';
import { SECTIONS, FLAT_GUIDES } from '../../data/guides';
import { loadExtensions, loadSeries } from '../../data/extensions';

const [extensions, series] = await Promise.all([loadExtensions(), loadSeries()]);
const totalGuides = FLAT_GUIDES.length;
const extCount = extensions.size;
---
<DocsLayout
  title="mcp-rune docs — the guides"
  description="Read the framework end to end, or jump to the part you need."
>
  <DocsHero />
  <FeaturedTrio />

  <section id="all">
    <div class="hub-wrap docs-wrap">
      <DocsSidebar />

      <div class="hub-content" id="ext-filter-root">
        <div class="ext-legend" data-screen-label="docs-ext-legend">
          <span class="ext-legend-avatar"><PlugIcon size={20} /></span>

          <div class="ext-legend-copy">
            <div class="ext-legend-title-row">
              <span class="ext-legend-title">Spot what you can extend</span>
              <ExtFlag variant="chip" />
            </div>
            <div class="ext-legend-body">
              The <span class="ext-legend-accent">plug</span> mark flags guides with an extension point — a place to drop in your own plugin, hook, strategy or override. <span class="ext-legend-count">{extCount} of {totalGuides} guides</span> expose one.
            </div>
          </div>

          <button
            id="ext-only-toggle"
            type="button"
            class="ext-toggle"
            aria-pressed="false"
            aria-controls="ext-filter-root"
          >
            <span class="ext-toggle-track">
              <span class="ext-toggle-knob" />
            </span>
            Extension points only
          </button>
        </div>

        {SECTIONS.map((section) => (
          <SectionBlock section={section} extensions={extensions} series={series} />
        ))}

        <ContributionCallout />
      </div>
    </div>
  </section>
</DocsLayout>

<script>
  // "Extension points only" toggle. Vanilla because the page is static.
  const root = document.getElementById('ext-filter-root');
  const btn = document.getElementById('ext-only-toggle') as HTMLButtonElement | null;
  if (root && btn) {
    const update = () => {
      const on = root.classList.contains('ext-only');
      btn.setAttribute('aria-pressed', String(on));
      root.querySelectorAll<HTMLElement>('.section-block').forEach((section) => {
        const total = Number(section.dataset.totalCount ?? 0);
        const ext = Number(section.dataset.extCount ?? 0);
        const count = on ? ext : total;
        const counter = section.querySelector('.section-count');
        if (counter) {
          counter.textContent = `${count} GUIDE${count === 1 ? '' : 'S'}`;
        }
      });
    };
    btn.addEventListener('click', () => {
      root.classList.toggle('ext-only');
      update();
    });
  }
</script>

<style>
  .hub-wrap {
    padding: 56px 32px 96px;
    display: flex;
    gap: 48px;
    align-items: flex-start;
  }
  .hub-content { flex: 1; min-width: 0; }

  @media (max-width: 1024px) {
    .hub-wrap { gap: 24px; }
  }
  @media (max-width: 768px) {
    .hub-wrap { padding: 32px 16px 64px; }
  }

  /* ── Extensibility legend + toggle ─────────────────────────── */
  .ext-legend {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 16px 20px;
    margin-bottom: 40px;
    background: linear-gradient(100deg, rgba(91, 184, 245, 0.1) 0%, transparent 70%);
    border: 1px solid rgba(91, 184, 245, 0.34);
    border-radius: 10px;
  }
  .ext-legend-avatar {
    width: 40px;
    height: 40px;
    border-radius: 9px;
    flex-shrink: 0;
    background: rgba(91, 184, 245, 0.1);
    border: 1px solid rgba(91, 184, 245, 0.34);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #5bb8f5;
  }
  .ext-legend-copy { flex: 1; min-width: 0; }
  .ext-legend-title-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 3px;
  }
  .ext-legend-title {
    font-family: 'Geist', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .ext-legend-body {
    font-size: 13px;
    color: var(--ink-3);
    line-height: 1.5;
  }
  .ext-legend-accent { color: #5bb8f5; }
  .ext-legend-count { color: var(--ink-2); }

  .ext-toggle {
    flex-shrink: 0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 36px;
    padding: 0 14px;
    border-radius: 7px;
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.3px;
    background: transparent;
    color: #5bb8f5;
    border: 1px solid rgba(91, 184, 245, 0.34);
    transition: background 120ms, color 120ms, border-color 120ms;
  }
  .ext-toggle-track {
    width: 26px;
    height: 15px;
    border-radius: 999px;
    flex-shrink: 0;
    background: var(--line-3);
    position: relative;
    transition: background 120ms;
  }
  .ext-toggle-knob {
    position: absolute;
    top: 2px;
    left: 2px;
    width: 11px;
    height: 11px;
    border-radius: 999px;
    background: var(--ink-3);
    transition: left 120ms, background 120ms;
  }
  .ext-only .ext-toggle {
    background: #5bb8f5;
    color: #07070a;
    border-color: #5bb8f5;
  }
  .ext-only .ext-toggle-track { background: #07070a; }
  .ext-only .ext-toggle-knob {
    left: 13px;
    background: #5bb8f5;
  }

  /* When the toggle is on: hide non-extensible rows + any section that
     becomes empty as a result. */
  .ext-only .guide-row[data-ext='false'] { display: none; }
  .ext-only .section-block[data-ext-count='0'] { display: none; }

  @media (max-width: 768px) {
    .ext-legend {
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
    }
    .ext-toggle { align-self: stretch; justify-content: center; }
  }
</style>
