---
import '../styles/global.css';
import { UMAMI_SRC, UMAMI_WEBSITE_ID } from '../lib/site';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'mcp-rune — the framework for model-driven MCP servers.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {/* Umami — self-hosted, cookieless analytics (no consent banner needed).
        Production only, so `astro dev` doesn't pollute stats. is:inline keeps
        Astro from bundling the third-party tag. Config: src/lib/site.ts */}
    {import.meta.env.PROD && (
      <script is:inline defer src={UMAMI_SRC} data-website-id={UMAMI_WEBSITE_ID}></script>
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
