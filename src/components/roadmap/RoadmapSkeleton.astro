---
import RoadmapStatusPill from './RoadmapStatusPill.astro';

interface Props {
  caption: string;
  version: string;
  hintCount?: number;
  /** When this is the first skeleton, expose the section eyebrow above it. */
  showHeader?: boolean;
}
const { caption, version, hintCount = 5, showHeader = false } = Astro.props;
const rows = Array.from({ length: hintCount });
---
{showHeader && (
  <section class="rm-skel-header-wrap">
    <div class="rm-skel-header-inner">
      <div class="rm-skel-header-row">
        <div class="rm-skel-header-eyebrow">
          <span class="rm-skel-header-glyph">◇</span> Placeholders · awaiting GitHub milestones
        </div>
        <div class="rm-skel-header-rule" />
      </div>
    </div>
  </section>
)}

<section class="rm-skel-wrap">
  <div class="rm-skel-inner">
    <section class="rm-skel">
      <div class="rm-skel-rail">
        <div class="rm-skel-caption">{caption}</div>
        <div class="pr-display rm-skel-version">{version}</div>
        <div class="rm-skel-date" />
        <div class="rm-skel-lines">
          <div class="rm-skel-line" style="width: 100%;" />
          <div class="rm-skel-line" style="width: 85%;" />
          <div class="rm-skel-line" style="width: 60%;" />
        </div>
      </div>
      <ul class="rm-skel-items">
        {rows.map(() => (
          <li class="rm-skel-row">
            <div class="rm-skel-line" style="width: 50%;" />
            <div class="rm-skel-row-mid">
              <div class="rm-skel-line" style="width: 70%;" />
              <div class="rm-skel-line rm-skel-line-faint" style="width: 92%;" />
            </div>
            <RoadmapStatusPill kind="empty" />
            <div class="rm-skel-line rm-skel-line-end" />
          </li>
        ))}
        <li class="rm-skel-row-end" />
      </ul>
    </section>
  </div>
</section>

<style>
  .rm-skel-header-wrap {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .rm-skel-header-inner { padding-top: 40px; }
  .rm-skel-header-row {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .rm-skel-header-eyebrow {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.5px;
    color: var(--ink-4);
    text-transform: uppercase;
  }
  .rm-skel-header-glyph { color: var(--ink-4); }
  .rm-skel-header-rule { flex: 1; height: 1px; background: var(--line); }

  .rm-skel-wrap {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .rm-skel {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 56px;
    padding: 40px 0 8px;
    border-top: 1px solid var(--line-2);
    opacity: 0.78;
  }
  .rm-skel-caption {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--ink-4);
    letter-spacing: 0.5px;
    margin-bottom: 8px;
  }
  .rm-skel-version {
    font-size: 44px;
    color: var(--ink-3);
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 10px;
  }
  .rm-skel-date {
    display: inline-block;
    height: 14px;
    width: 110px;
    margin-bottom: 18px;
    background: var(--surface);
    border: 1px dashed var(--line-2);
    border-radius: 4px;
  }
  .rm-skel-lines {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-width: 220px;
  }
  .rm-skel-line {
    height: 10px;
    background: var(--surface);
    border-radius: 3px;
  }
  .rm-skel-line-faint { opacity: 0.7; }
  .rm-skel-line-end { justify-self: end; width: 38px; }

  .rm-skel-items { list-style: none; margin: 0; padding: 0; }
  .rm-skel-row {
    display: grid;
    grid-template-columns: 120px 1fr auto 90px;
    gap: 18px;
    align-items: center;
    padding: 18px 0;
    border-top: 1px solid var(--line);
  }
  .rm-skel-row-mid { display: flex; flex-direction: column; gap: 6px; }
  .rm-skel-row-end { border-top: 1px solid var(--line); height: 0; }

  @media (max-width: 768px) {
    .rm-skel-header-wrap, .rm-skel-wrap { padding: 0 16px; }
    .rm-skel {
      grid-template-columns: 1fr;
      gap: 14px;
      padding: 20px 0 8px;
    }
    .rm-skel-version { font-size: 32px; }
    .rm-skel-row {
      grid-template-columns: 1fr;
      gap: 6px;
      padding: 14px 0;
    }
    .rm-skel-line-end { justify-self: start; }
  }
</style>
