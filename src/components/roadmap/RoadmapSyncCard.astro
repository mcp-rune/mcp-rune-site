---
import type { RoadmapData } from '../../lib/github-milestones';

interface Props {
  data: RoadmapData | null;
}
const { data } = Astro.props;

const connected = data !== null;
const source = data?.source ?? 'github.com/mcp-rune/mcp-rune/milestones';
const milestonesCount = data ? String(data.milestones.length) : '—';
const openIssues = data ? String(data.openIssueCount) : '—';
const lastSync = data ? 'just now' : 'never';
const githubUrl = `https://${source}`;
---
<section class="rm-sync-wrap">
  <div class="rm-sync-card" data-state={connected ? 'connected' : 'disconnected'}>
    <div class="rm-sync-status">
      <span class="rm-sync-dot" />
      <span class="rm-sync-label">{connected ? 'connected' : 'disconnected'}</span>
    </div>

    <div class="rm-sync-cell">
      <span class="rm-sync-cell-label">source</span>
      <span class="rm-sync-cell-value mono">{source}</span>
    </div>
    <div class="rm-sync-cell">
      <span class="rm-sync-cell-label">milestones</span>
      <span class="rm-sync-cell-value mono">{milestonesCount}</span>
    </div>
    <div class="rm-sync-cell">
      <span class="rm-sync-cell-label">open issues</span>
      <span class="rm-sync-cell-value mono">{openIssues}</span>
    </div>
    <div class="rm-sync-cell">
      <span class="rm-sync-cell-label">last sync</span>
      <span class="rm-sync-cell-value mono">{lastSync}</span>
    </div>

    <a href={githubUrl} class="pr-btn ghost rm-sync-btn">
      <span class="rm-sync-arr">↗</span> Open on GitHub
    </a>
  </div>

  <p class="rm-sync-note">
    {connected ? (
      <>
        This page reads from the project’s GitHub Milestones. We haven’t created any yet,
        so it’s empty by design — the structure below is a worked example of what each
        milestone <em>will</em> look like once it exists. Nothing here is hand-edited;
        every field is mapped to a GitHub source (hover any dashed pill to see the field).
      </>
    ) : (
      <>
        Build-time fetch of the GitHub Milestones API is currently disabled because
        <code> GITHUB_TOKEN </code> isn’t set. The empty-state layout below still shows
        the design the page will take on once the token is plumbed through and the
        first milestones exist.
      </>
    )}
  </p>
</section>

<style>
  .rm-sync-wrap {
    max-width: 1440px;
    margin: 0 auto;
    padding: 8px 32px 40px;
  }
  .rm-sync-card {
    position: relative;
    padding: 22px 28px;
    background: linear-gradient(180deg, rgba(124, 92, 255, 0.06), rgba(124, 92, 255, 0.02));
    border: 1px solid var(--line-2);
    border-radius: 10px;
    display: grid;
    grid-template-columns: auto 1fr auto auto auto auto;
    gap: 32px;
    align-items: center;
  }
  .rm-sync-status {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .rm-sync-dot {
    position: relative;
    width: 10px;
    height: 10px;
    border-radius: 5px;
  }
  .rm-sync-card[data-state='connected'] .rm-sync-dot {
    background: #7ee2c1;
    box-shadow: 0 0 0 4px rgba(126, 226, 193, 0.18);
  }
  .rm-sync-card[data-state='disconnected'] .rm-sync-dot {
    background: #f87171;
    box-shadow: 0 0 0 4px rgba(248, 113, 113, 0.18);
  }
  .rm-sync-label {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--ink);
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .rm-sync-cell {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .rm-sync-cell-label {
    font-family: 'Geist Mono', monospace;
    font-size: 10.5px;
    color: var(--ink-4);
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .rm-sync-cell-value {
    font-size: 13px;
    color: var(--ink);
    letter-spacing: -0.005em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .rm-sync-cell-value.mono { font-family: 'Geist Mono', monospace; }
  .rm-sync-btn { height: 32px; padding: 0 12px; font-size: 12px; }
  .rm-sync-arr { color: var(--ink-3); }
  .rm-sync-note {
    margin-top: 14px;
    font-size: 13px;
    line-height: 1.6;
    color: var(--ink-3);
    max-width: 820px;
  }
  .rm-sync-note code {
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    color: var(--ink-2);
    background: var(--bg-3);
    border: 1px solid var(--line);
    padding: 1px 6px;
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .rm-sync-wrap { padding: 8px 16px 24px; }
    .rm-sync-card {
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      padding: 16px 18px;
    }
    .rm-sync-status { grid-column: 1 / -1; }
    .rm-sync-btn { grid-column: 1 / -1; justify-content: center; }
  }
</style>
