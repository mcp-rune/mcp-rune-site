---
const SLOT_BASE = 'pulled from GitHub Milestones → ';
const STATUS_TOOLTIP =
  'issue.labels matching "status:*" — REQUIRED. Issues without a status:* label are hidden from the roadmap.';
---
<section class="rm-ann">
  <div class="rm-ann-inner">
    <div class="rm-ann-header">
      <div class="rm-ann-eyebrow">
        <span class="rm-ann-glyph">◇</span> Worked example · field mapping
      </div>
      <div class="rm-ann-rule" />
      <span class="rm-ann-hint">hover any dashed pill</span>
    </div>

    <section class="rm-ann-body">
      <div class="rm-ann-rail">
        <div class="rm-ann-rail-status">
          <span class="rm-slot" title={SLOT_BASE + 'milestone.state → caption'}>
            <span class="rm-slot-brace">{'{'}</span>milestone.state<span class="rm-slot-brace">{'}'}</span>
          </span>
        </div>
        <div class="rm-ann-rail-version">
          <span class="rm-ann-rail-version-text">milestone.title</span>
        </div>
        <div class="rm-ann-rail-name">
          <span class="rm-slot" title={SLOT_BASE + 'milestone.description, first line ending in "..."'}>
            <span class="rm-slot-brace">{'{'}</span>first line of description …<span class="rm-slot-brace">{'}'}</span>
          </span>
        </div>
        <div class="rm-ann-rail-target">
          <span class="rm-slot" title={SLOT_BASE + 'milestone.due_on'}>
            <span class="rm-slot-brace">{'{'}</span>milestone.due_on<span class="rm-slot-brace">{'}'}</span>
          </span>
        </div>
        <p class="rm-ann-rail-blurb">
          <span
            class="rm-slot rm-slot-block"
            title={SLOT_BASE + 'milestone.description, paragraphs after the first line'}
          >
            <span class="rm-slot-brace">{'{'}</span>milestone.description (rest of body) — markdown allowed.<span class="rm-slot-brace">{'}'}</span>
          </span>
        </p>
      </div>

      <ul class="rm-ann-items">
        {[0, 1, 2].map(() => (
          <li class="rm-ann-row">
            <span class="rm-ann-area">
              <span class="rm-slot" title={SLOT_BASE + 'issue.labels matching "area:*"'}>
                <span class="rm-slot-brace">{'{'}</span>area:*<span class="rm-slot-brace">{'}'}</span>
              </span>
            </span>
            <div>
              <div class="rm-ann-title">
                <span class="rm-slot" title={SLOT_BASE + 'issue.title'}>
                  <span class="rm-slot-brace">{'{'}</span>issue.title<span class="rm-slot-brace">{'}'}</span>
                </span>
              </div>
              <div class="rm-ann-hint-row">
                <span class="rm-slot" title={SLOT_BASE + 'issue.body, first paragraph'}>
                  <span class="rm-slot-brace">{'{'}</span>issue.body — one-line hint, first paragraph only<span class="rm-slot-brace">{'}'}</span>
                </span>
              </div>
            </div>
            <span>
              <span class="rm-slot" title={STATUS_TOOLTIP}>
                <span class="rm-slot-brace">{'{'}</span>status:*<span class="rm-slot-brace">{'}'}</span>
              </span>
            </span>
            <span class="rm-ann-issue-cell">
              <span class="rm-slot" title={SLOT_BASE + 'issue.number → issue.html_url'}>
                <span class="rm-slot-brace">{'{'}</span>#issue.number<span class="rm-slot-brace">{'}'}</span>
              </span>
            </span>
          </li>
        ))}
        <li class="rm-ann-row-end" />
      </ul>
    </section>
  </div>
</section>

<style>
  .rm-ann { border-top: 1px solid var(--line-2); }
  .rm-ann-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 32px 32px 8px;
  }
  .rm-ann-header {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-bottom: 8px;
  }
  .rm-ann-eyebrow {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.5px;
    color: var(--ink-4);
    text-transform: uppercase;
  }
  .rm-ann-glyph { color: var(--acc-2); }
  .rm-ann-rule { flex: 1; height: 1px; background: var(--line); }
  .rm-ann-hint {
    font-family: 'Geist Mono', monospace;
    font-size: 10.5px;
    color: var(--ink-4);
    letter-spacing: 0.4px;
  }

  .rm-ann-body {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 56px;
    padding: 32px 0 12px;
  }
  .rm-ann-rail-status { margin-bottom: 8px; font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--ink-4); letter-spacing: 0.5px; }
  .rm-ann-rail-version {
    border: 1px dashed var(--line-2);
    border-radius: 6px;
    padding: 4px 10px;
    display: inline-block;
    margin-bottom: 10px;
  }
  .rm-ann-rail-version-text {
    font-family: 'Geist', sans-serif;
    font-weight: 500;
    font-size: 44px;
    color: var(--ink-4);
    letter-spacing: -0.04em;
    line-height: 1;
  }
  .rm-ann-rail-name {
    font-family: 'Geist', sans-serif;
    font-size: 14px;
    color: var(--ink-3);
    margin-bottom: 14px;
    font-style: italic;
  }
  .rm-ann-rail-target { margin-bottom: 18px; }
  .rm-ann-rail-blurb {
    font-size: 13px;
    color: var(--ink-3);
    line-height: 1.55;
    max-width: 220px;
  }

  .rm-ann-items { list-style: none; margin: 0; padding: 0; }
  .rm-ann-row {
    display: grid;
    grid-template-columns: 160px 1fr auto 110px;
    gap: 18px;
    align-items: baseline;
    padding: 16px 0;
    border-top: 1px solid var(--line);
  }
  .rm-ann-row-end { border-top: 1px solid var(--line); height: 0; }
  .rm-ann-area { padding-top: 2px; }
  .rm-ann-title { font-size: 15px; color: var(--ink-2); letter-spacing: -0.005em; margin-bottom: 4px; }
  .rm-ann-hint-row { font-size: 12px; color: var(--ink-4); }
  .rm-ann-issue-cell { text-align: right; }

  .rm-slot {
    display: inline-block;
    padding: 1px 8px;
    border-radius: 4px;
    background: rgba(124, 92, 255, 0.05);
    border: 1px dashed rgba(124, 92, 255, 0.28);
    color: var(--ink-3);
    font-family: 'Geist Mono', monospace;
    font-size: 11.5px;
    letter-spacing: 0.2px;
    cursor: help;
  }
  .rm-slot-block {
    display: block;
    padding: 8px 10px;
    white-space: normal;
  }
  .rm-slot-brace { color: var(--acc-2); opacity: 0.7; }
  .rm-slot-brace:first-child { margin-right: 6px; }
  .rm-slot-brace:last-child { margin-left: 6px; }

  @media (max-width: 768px) {
    .rm-ann-inner { padding: 20px 16px 8px; }
    .rm-ann-body {
      grid-template-columns: 1fr;
      gap: 18px;
      padding: 16px 0 8px;
    }
    .rm-ann-row {
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .rm-ann-issue-cell { text-align: left; }
    .rm-ann-rail-version-text { font-size: 32px; }
  }
</style>
