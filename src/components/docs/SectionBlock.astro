---
import GuideRow from './GuideRow.astro';
import PlugIcon from './PlugIcon.astro';
import type { Section } from '../../data/guides';
import type { ExtensionPoint } from '../../data/extensions';

interface Props {
  section: Section;
  extensions?: Map<string, ExtensionPoint>;
}
const { section, extensions } = Astro.props;
const extCount = extensions
  ? section.guides.filter((g) => extensions.has(g.slug)).length
  : 0;
---
<div
  class="section-block"
  id={`section-${section.num.toLowerCase()}`}
  data-ext-count={extCount}
  data-total-count={section.guides.length}
>
  <div class="section-head">
    <div class="section-num">{section.num}. SECTION</div>
    <h2 class="pr-display section-title">{section.title}</h2>
    {extCount > 0 && (
      <span
        class="section-ext-pill"
        title={`${extCount} extension point${extCount === 1 ? '' : 's'} in this section`}
      >
        <PlugIcon size={11} />
        {extCount} EXTENSIBLE
      </span>
    )}
    <span class="section-bar" />
    <span class="section-count" data-section-count-default={section.guides.length}>
      {section.guides.length} GUIDE{section.guides.length === 1 ? '' : 'S'}
    </span>
  </div>
  {section.blurb && <p class="section-blurb">{section.blurb}</p>}

  <div class="section-rows">
    {section.guides.map((guide, i) => (
      <GuideRow guide={guide} index={i + 1} extension={extensions?.get(guide.slug)} />
    ))}
  </div>
</div>

<style>
  .section-block { margin-bottom: 56px; }
  .section-head {
    display: flex;
    align-items: flex-end;
    gap: 16px;
    margin-bottom: 18px;
  }
  .section-num {
    font-family: 'Geist Mono', monospace;
    font-size: 11.5px;
    color: var(--acc-2);
    letter-spacing: 0.5px;
  }
  .section-title {
    font-size: 30px;
    margin: 0;
    color: var(--ink);
  }
  .section-ext-pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 2px 8px 2px 6px;
    border-radius: 4px;
    font-family: 'Geist Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.4px;
    background: rgba(91, 184, 245, 0.1);
    border: 1px solid rgba(91, 184, 245, 0.34);
    color: #5bb8f5;
    white-space: nowrap;
  }
  .section-bar {
    flex: 1;
    height: 1px;
    background: var(--line);
  }
  .section-count {
    font-family: 'Geist Mono', monospace;
    font-size: 11.5px;
    color: var(--ink-4);
    white-space: nowrap;
  }
  .section-blurb {
    font-size: 14px;
    color: var(--ink-3);
    max-width: 720px;
    margin: 0 0 18px;
  }
  .section-rows {
    background: var(--surface);
    border: 1px solid var(--line-2);
    border-top: none;
    border-radius: 8px;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .section-block { margin-bottom: 40px; }
    .section-head {
      flex-direction: column;
      align-items: flex-start;
      gap: 6px;
      margin-bottom: 14px;
    }
    .section-title { font-size: 24px; }
    .section-bar { display: none; }
  }
</style>
