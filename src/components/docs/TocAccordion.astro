---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}
const { headings } = Astro.props;
const items = headings.filter((h) => h.depth === 2);
---
{items.length > 0 && (
  <details class="toc-acc">
    <summary class="toc-acc-summary">
      <span class="toc-acc-eyebrow">On this page</span>
      <span class="toc-acc-spacer" />
      <span class="toc-acc-count">{items.length} section{items.length === 1 ? '' : 's'}</span>
      <span class="toc-acc-chev" aria-hidden="true">
        <svg width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <path d="M2 4l3.5 3.5L9 4" />
        </svg>
      </span>
    </summary>
    <ul class="toc-acc-list">
      {items.map((h) => (
        <li>
          <a href={`#${h.slug}`}>{h.text}</a>
        </li>
      ))}
    </ul>
  </details>
)}

<style>
  .toc-acc {
    display: none;
    margin-bottom: 20px;
  }
  .toc-acc-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--ink);
    font-family: 'Geist', sans-serif;
    font-size: 13px;
    font-weight: 500;
  }
  .toc-acc-summary::-webkit-details-marker { display: none; }
  .toc-acc[open] .toc-acc-summary {
    border-radius: 8px 8px 0 0;
    border-bottom-color: var(--line-2);
  }
  .toc-acc-eyebrow {
    font-family: 'Geist Mono', monospace;
    font-size: 10px;
    color: var(--ink-4);
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .toc-acc-spacer { flex: 1; }
  .toc-acc-count {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--ink-3);
  }
  .toc-acc-chev {
    color: var(--ink-3);
    display: inline-flex;
    transition: transform 0.15s;
  }
  .toc-acc[open] .toc-acc-chev { transform: rotate(180deg); }
  .toc-acc-list {
    list-style: none;
    margin: 0;
    padding: 6px 8px 10px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-top: none;
    border-radius: 0 0 8px 8px;
  }
  .toc-acc-list a {
    display: flex;
    align-items: center;
    padding: 8px 10px;
    border-radius: 5px;
    font-size: 13px;
    color: var(--ink-2);
    border-left: 2px solid transparent;
  }
  .toc-acc-list a:hover {
    color: var(--ink);
    background: rgba(124, 92, 255, 0.06);
    border-left-color: var(--acc);
    padding-left: 8px;
  }

  @media (max-width: 1024px) {
    .toc-acc { display: block; }
  }
</style>
