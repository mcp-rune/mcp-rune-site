    <path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z" />
  </svg>
)}
{name === 'schema' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
    <rect x="3" y="3" width="7" height="5" />
    <rect x="14" y="3" width="7" height="5" />
    <rect x="3" y="11" width="7" height="5" />
    <rect x="14" y="11" width="7" height="5" />
    <rect x="3" y="19" width="7" height="2" />
    <rect x="14" y="19" width="7" height="2" />
  </svg>
)}
{name === 'layers' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
    <path d="M12 2L2 7l10 5 10-5-10-5z" />
