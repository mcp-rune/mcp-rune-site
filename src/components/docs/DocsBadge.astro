---
import type { GuideStatus } from '../../data/guides';

interface Props {
  kind?: GuideStatus;
}
const { kind = 'live' } = Astro.props;
---
<span class:list={['badge', kind]}>
  <span class="dot"></span>
  {kind}
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 2px 8px;
    border-radius: 4px;
    font-family: 'Geist Mono', monospace;
    font-size: 10.5px;
    letter-spacing: 0.4px;
    text-transform: uppercase;
  }
  .dot {
    width: 5px;
    height: 5px;
    border-radius: 3px;
    background: currentColor;
  }
  .badge.live {
    color: #7ee2c1;
    background: rgba(126, 226, 193, 0.1);
    border: 1px solid rgba(126, 226, 193, 0.3);
  }
  .badge.wip {
    color: #f0c674;
    background: rgba(240, 198, 116, 0.1);
    border: 1px solid rgba(240, 198, 116, 0.3);
  }
  .badge.soon {
    color: #a78bfa;
    background: rgba(124, 92, 255, 0.1);
    border: 1px solid rgba(124, 92, 255, 0.3);
  }
</style>
