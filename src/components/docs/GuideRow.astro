---
import DocIcon from './DocIcon.astro';
import DocsBadge from './DocsBadge.astro';
import type { Guide } from '../../data/guides';

interface Props {
  guide: Guide;
  /** 1-based ordinal within the section. */
  index: number;
}
const { guide, index } = Astro.props;
const href = guide.status === 'live' ? `/docs/${guide.slug}` : undefined;
const Tag = href ? 'a' : 'div';
---
<Tag class:list={['guide-row', { live: guide.status === 'live', disabled: !href }]} href={href}>
  <span class="row-icon">
    <DocIcon name={guide.icon} size={22} />
  </span>

  <span class="row-num">§ {String(index).padStart(2, '0')}</span>

  <span class="row-label">{guide.label}</span>

  <span class="row-blurb">{guide.blurb}</span>

  <span class="row-tags">
    {(guide.tags ?? []).map((t) => (
      <span class="tag">{t}</span>
    ))}
  </span>

  <span class="row-meta">
    <DocsBadge kind={guide.status} />
    <span class="row-read">{guide.read}</span>
  </span>

  <span class="row-arr">→</span>
</Tag>

<style>
  .guide-row {
    display: grid;
    grid-template-columns: 48px 50px 1.4fr 2fr 90px 80px 18px;
    gap: 18px;
    align-items: center;
    padding: 18px 22px;
    border-top: 1px solid var(--line);
    background: var(--surface);
    color: inherit;
    text-decoration: none;
    transition: background 120ms;
  }
  .guide-row:first-child { border-top: 1px solid var(--line-2); }
  .guide-row.live:hover { background: var(--surface-2); }
  .guide-row.disabled { cursor: default; opacity: 0.78; }

  .row-icon {
    width: 36px;
    height: 36px;
    border-radius: 7px;
    background: rgba(124, 92, 255, 0.06);
    border: 1px solid rgba(124, 92, 255, 0.18);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--acc-2);
  }
  .row-num {
    font-family: 'Geist Mono', monospace;
    font-size: 11.5px;
    color: var(--ink-4);
    letter-spacing: 0.4px;
  }
  .row-label {
    font-family: 'Geist', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .row-blurb {
    font-size: 13.5px;
    color: var(--ink-3);
    line-height: 1.5;
  }
  .row-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .tag {
    font-family: 'Geist Mono', monospace;
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 3px;
    background: var(--bg-2);
    border: 1px solid var(--line-2);
    color: var(--ink-3);
  }
  .row-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }
  .row-read {
    font-family: 'Geist Mono', monospace;
    font-size: 10.5px;
    color: var(--ink-4);
  }
  .row-arr {
    color: var(--ink-4);
    text-align: right;
  }
</style>
