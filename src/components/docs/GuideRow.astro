---
import DocIcon from './DocIcon.astro';
import DocsBadge from './DocsBadge.astro';
import ExtFlag from './ExtFlag.astro';
import PlugIcon from './PlugIcon.astro';
import type { Guide } from '../../data/guides';
import type { ExtensionPoint } from '../../data/extensions';

interface Props {
  guide: Guide;
  /** 1-based ordinal within the section. */
  index: number;
  extension?: ExtensionPoint;
}
const { guide, index, extension } = Astro.props;
const href = guide.status === 'live' ? `/docs/${guide.slug}` : undefined;
const Tag = href ? 'a' : 'div';
---
<Tag
  class:list={['guide-row', { live: guide.status === 'live', disabled: !href, ext: !!extension }]}
  href={href}
  data-ext={extension ? 'true' : 'false'}
  data-ext-slug={guide.slug}
>
  <span class="row-icon">
    <DocIcon name={guide.icon} size={22} />
    {extension && (
      <span class="row-icon-badge" title={`Extension point — ${extension.what}`}>
        <PlugIcon size={9} color="#07070a" />
      </span>
    )}
  </span>

  <span class="row-num">§ {String(index).padStart(2, '0')}</span>

  <span class="row-label-col">
    <span class="row-label">{guide.label}</span>
    {extension && (
      <span class="row-ext">
        <ExtFlag variant="chip" />
        <span class="row-ext-what">{extension.what}</span>
      </span>
    )}
  </span>

  <span class="row-blurb">{guide.blurb}</span>

  <span class="row-tags">
    {(guide.tags ?? []).map((t) => (
      <span class="tag">{t}</span>
    ))}
  </span>

  <span class="row-meta">
    <DocsBadge kind={guide.status} />
    <span class="row-read">{guide.read}</span>
  </span>

  <span class="row-arr">→</span>
</Tag>

<style>
  .guide-row {
    display: grid;
    grid-template-columns: 48px 50px 1.4fr 2fr 90px 80px 18px;
    gap: 18px;
    align-items: center;
    padding: 18px 22px;
    border-top: 1px solid var(--line);
    background: var(--surface);
    color: inherit;
    text-decoration: none;
    transition: background 120ms;
  }
  .guide-row:first-child { border-top: 1px solid var(--line-2); }
  .guide-row.live:hover { background: var(--surface-2); }
  .guide-row.disabled { cursor: default; opacity: 0.78; }

  .row-icon {
    position: relative;
    width: 36px;
    height: 36px;
    border-radius: 7px;
    background: rgba(124, 92, 255, 0.06);
    border: 1px solid rgba(124, 92, 255, 0.18);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--acc-2);
  }
  .guide-row.ext .row-icon {
    background: rgba(91, 184, 245, 0.1);
    border-color: rgba(91, 184, 245, 0.34);
    color: #5bb8f5;
  }
  .row-icon-badge {
    position: absolute;
    top: -6px;
    right: -6px;
    width: 17px;
    height: 17px;
    border-radius: 5px;
    background: #5bb8f5;
    color: #07070a;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--surface);
  }
  .row-num {
    font-family: 'Geist Mono', monospace;
    font-size: 11.5px;
    color: var(--ink-4);
    letter-spacing: 0.4px;
  }
  .row-label-col {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .row-label {
    font-family: 'Geist', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .row-ext {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-width: 0;
  }
  .row-ext-what {
    font-family: 'Geist Mono', monospace;
    font-size: 10.5px;
    color: var(--ink-4);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .row-blurb {
    font-size: 13.5px;
    color: var(--ink-3);
    line-height: 1.5;
  }
  .row-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .tag {
    font-family: 'Geist Mono', monospace;
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 3px;
    background: var(--bg-2);
    border: 1px solid var(--line-2);
    color: var(--ink-3);
  }
  .row-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }
  .row-read {
    font-family: 'Geist Mono', monospace;
    font-size: 10.5px;
    color: var(--ink-4);
  }
  .row-arr {
    color: var(--ink-4);
    text-align: right;
  }

  @media (max-width: 768px) {
    .guide-row {
      grid-template-columns: 40px 1fr auto;
      grid-template-areas:
        "icon label arr"
        "icon blurb arr"
        "icon meta  arr";
      column-gap: 12px;
      row-gap: 6px;
      padding: 14px 16px;
    }
    .row-icon {
      grid-area: icon;
      align-self: start;
      width: 32px;
      height: 32px;
    }
    .row-num,
    .row-tags { display: none; }
    .row-label-col { grid-area: label; }
    .row-label { font-size: 15px; }
    .row-ext-what { display: none; }
    .row-blurb { grid-area: blurb; font-size: 13px; }
    .row-meta {
      grid-area: meta;
      flex-direction: row;
      align-items: center;
      gap: 8px;
    }
    .row-arr { grid-area: arr; align-self: center; }
  }
</style>
