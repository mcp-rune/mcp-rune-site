---
import { SECTIONS, FLAT_GUIDES, isReadable } from '../data/guides';
import { loadExtensions } from '../data/extensions';
import { MCP_RUNE_VERSION_LABEL } from '../data/version';
import ExtFlag from './docs/ExtFlag.astro';
import PlugIcon from './docs/PlugIcon.astro';

interface Props {
  activeSlug?: string;
}
const { activeSlug } = Astro.props;
const extensions = await loadExtensions();
---
<aside class="docs-sidebar">
  <div class="sidebar-version">{MCP_RUNE_VERSION_LABEL} · {FLAT_GUIDES.length} guides</div>

  <div class="sidebar-ext-key">
    <span class="ext-key-icon"><PlugIcon size={13} /></span>
    <span class="ext-key-label">
      marks an <span class="ext-key-em">extension point</span>
    </span>
    <span class="ext-key-spacer" />
    <span class="ext-key-count">{extensions.size}</span>
  </div>

  {SECTIONS.map((section) => (
    <div class="sidebar-section">
      <div class="section-heading">
        <span class="section-num">{section.num}.</span>
        <span>{section.title}</span>
      </div>
      <ul class="section-list">
        {section.guides.map((guide) => {
          const on = guide.slug === activeSlug;
          const readable = isReadable(guide.status);
          const href = readable ? `/docs/${guide.slug}` : '#';
          const ext = extensions.get(guide.slug);
          return (
            <li>
              <a href={href} class:list={['guide-link', { on, disabled: !readable }]}>
                <span class="guide-label">{guide.label}</span>
                {ext && <ExtFlag variant="icon" what={ext.what} />}
                {guide.status !== 'live' && (
                  <span class:list={['guide-status', `s-${guide.status}`]}>{guide.status}</span>
                )}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  ))}
</aside>

<style>
  .docs-sidebar {
    width: 256px;
    flex-shrink: 0;
    position: sticky;
    top: 80px;
    align-self: flex-start;
    max-height: calc(100vh - 96px);
    overflow-y: auto;
    padding-right: 8px;
  }
  .sidebar-version {
    font-family: 'Geist Mono', monospace;
    font-size: 10.5px;
    letter-spacing: 0.5px;
    color: var(--ink-4);
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .sidebar-ext-key {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 10px;
    margin-bottom: 22px;
    background: rgba(91, 184, 245, 0.1);
    border: 1px solid rgba(91, 184, 245, 0.34);
    border-radius: 6px;
  }
  .ext-key-icon {
    color: #5bb8f5;
    display: inline-flex;
  }
  .ext-key-label {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--ink-2);
    letter-spacing: 0.2px;
  }
  .ext-key-em { color: #5bb8f5; }
  .ext-key-spacer { flex: 1; }
  .ext-key-count {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: #5bb8f5;
  }

  .sidebar-section { margin-bottom: 22px; }
  .section-heading {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-family: 'Geist Mono', monospace;
    font-size: 10.5px;
    color: var(--ink-4);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .section-num { color: var(--acc-2); }
  .section-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .guide-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 5px 8px 5px 10px;
    border-radius: 5px;
    font-size: 13px;
    letter-spacing: -0.005em;
    color: var(--ink-2);
    border-left: 2px solid transparent;
  }
  .guide-link:hover { color: var(--ink); }
  .guide-link.on {
    color: var(--ink);
    background: rgba(124, 92, 255, 0.08);
    border-left-color: var(--acc);
    padding-left: 8px;
  }
  .guide-link.disabled {
    color: var(--ink-3);
    cursor: default;
  }
  .guide-label { flex: 1; }
  .guide-status {
    font-family: 'Geist Mono', monospace;
    font-size: 9.5px;
    color: #f0c674;
    letter-spacing: 0.4px;
  }
  .guide-status.s-new { color: #5bb8f5; }
  .guide-status.s-soon { color: #a78bfa; }

  @media (max-width: 1024px) {
    .docs-sidebar { display: none; }
  }
</style>
