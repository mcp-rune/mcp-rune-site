---
import CliSectionHeader from './CliSectionHeader.astro';

interface Prompt {
  n: string;
  q: string;
  hint: string;
  sample: string;
  body: string;
  writes: string[];
  cliEquiv: string;
}

const PROMPTS: Prompt[] = [
  {
    n: '01',
    q: 'Models to scaffold',
    hint: 'comma-separated, empty for none',
    sample: 'book,shelf,home',
    body: 'Each name becomes a file in src/models/ — a BaseModel subclass with attributes, associations, filters and an api block. Empty input is valid; you can always add models later by editing the registry.',
    writes: ['src/models/book.ts', 'src/models/shelf.ts', 'src/models/home.ts'],
    cliEquiv: '--models book,shelf,home',
  },
  {
    n: '02',
    q: 'Transport?',
    hint: 'stdio · http · both',
    sample: 'both',
    body: 'stdio is fastest for local CLI clients, http is required for browser hosts. "Both" is the recommended default and adds ~3 KB to the bundle; the cost is negligible and the flexibility pays off the first time you connect from a second host.',
    writes: ['src/server.ts (stdio + http listeners)'],
    cliEquiv: '--transport both',
  },
  {
    n: '03',
    q: 'Enable analysis module?',
    hint: 'adds docker-compose.yml + pg dep',
    sample: 'Yes',
    body: 'Wires the analysis subsystem — Postgres for embeddings + a docker-compose.yml that boots it locally on port 5432. If you say no now, you can run rune add analysis later; the module is fully removable.',
    writes: ['docker-compose.yml', 'src/analysis/index.ts', '+ pg dependency'],
    cliEquiv: '--analysis',
  },
  {
    n: '04',
    q: 'Enable domain workflows?',
    hint: 'creates src/domain/ stubs',
    sample: 'Yes',
    body: 'Drops a populated src/domain/ — concepts, rules, diagrams, workflows — so the cross-entity registry has an obvious home from day one. Empty by default but linked into the main registry.',
    writes: ['src/domain/concepts.ts', 'src/domain/rules.ts', 'src/domain/workflows.ts'],
    cliEquiv: '--domain',
  },
];
---
<section class="cli-prompts">
  <div class="cli-prompts-inner">
    <CliSectionHeader
      number="02"
      eyebrow="INTERACTIVE PROMPTS"
      title="Four questions, in advanced mode."
      rightHint="skip all with --yes"
    />

    <p class="prompts-lede">
      Every prompt has a matching flag — pass it directly and the scaffolder skips the
      question. The defaults below are what <code>--yes</code> picks for you in advanced mode.
    </p>

    <div class="prompts-grid">
      {PROMPTS.map((p) => (
        <article class="prompt-card">
          <div class="prompt-top">
            <span class="prompt-n">{p.n}</span>
            <div class="prompt-body-col">
              <div class="prompt-qrow">
                <div class="prompt-q">{p.q}</div>
                <div class="prompt-hint">({p.hint})</div>
              </div>
              <div class="prompt-line">
                <span class="t-check">✓ </span>
                <span class="prompt-line-q">{p.q.toLowerCase()}…</span>
                <span class="prompt-line-a">{p.sample}</span>
              </div>
            </div>
          </div>

          <p class="prompt-blurb">{p.body}</p>

          <div class="prompt-meta">
            <span class="prompt-meta-k">WRITES</span>
            <div class="prompt-writes">
              {p.writes.map((w) => <span class="prompt-write">{w}</span>)}
            </div>
            <span class="prompt-meta-k">--YES</span>
            <span class="prompt-meta-v">
              defaults to <span class="prompt-default">{p.sample}</span> · or pass <span class="prompt-cli">{p.cliEquiv}</span>
            </span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .cli-prompts { border-bottom: 1px solid var(--line); }
  .cli-prompts-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 64px 32px;
  }
  .prompts-lede {
    font-size: 14.5px;
    color: var(--ink-3);
    max-width: 720px;
    margin: 0 0 32px;
  }
  .prompts-lede code {
    color: var(--ink-2);
    background: var(--bg-3);
    padding: 1px 5px;
    border-radius: 3px;
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
  }
  .prompts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .prompt-card {
    background: var(--surface);
    border: 1px solid var(--line-2);
    border-radius: 10px;
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .prompt-top {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }
  .prompt-n {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--acc-2);
    letter-spacing: 0.5px;
    padding-top: 4px;
  }
  .prompt-body-col { flex: 1; }
  .prompt-qrow {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }
  .prompt-q {
    font-family: 'Geist', sans-serif;
    font-size: 19px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.015em;
  }
  .prompt-hint {
    font-family: 'Geist Mono', monospace;
    font-size: 11.5px;
    color: var(--ink-4);
  }
  .prompt-line {
    margin-top: 10px;
    display: inline-flex;
    gap: 8px;
    align-items: center;
    padding: 6px 12px;
    background: var(--term-bg);
    border-radius: 6px;
    border: 1px solid var(--line-2);
    font-family: 'Geist Mono', monospace;
    font-size: 13px;
  }
  .prompt-line-q { color: var(--term-dim); }
  .prompt-line-a { color: var(--term-arg); font-weight: 600; }

  .prompt-blurb {
    margin: 0;
    font-size: 13.5px;
    color: var(--ink-3);
    line-height: 1.65;
  }
  .prompt-meta {
    padding-top: 14px;
    border-top: 1px dashed var(--line-2);
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 10px;
    font-family: 'Geist Mono', monospace;
    font-size: 11.5px;
  }
  .prompt-meta-k {
    color: var(--ink-4);
    letter-spacing: 0.3px;
  }
  .prompt-meta-v { color: var(--ink-2); }
  .prompt-writes {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .prompt-write { color: var(--acc-2); }
  .prompt-default { color: #7ee2c1; font-weight: 600; }
  .prompt-cli { color: var(--acc-2); }

  @media (max-width: 1024px) {
    .prompts-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .cli-prompts-inner { padding: 40px 16px; }
    .prompt-card { padding: 18px; }
    .prompt-q { font-size: 17px; }
  }
</style>
