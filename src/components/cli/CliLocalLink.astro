---
import Terminal from './Terminal.astro';
import CliSectionHeader from './CliSectionHeader.astro';

const WHEN: string[] = [
  "You're reading or contributing to the framework itself.",
  "You're reproducing a bug and want to bisect across both repos.",
  "You're on an unreleased branch with breaking changes.",
];
---
<section class="cli-local">
  <div class="cli-local-inner">
    <CliSectionHeader number="04" eyebrow="LOCAL LINK" title="">
      <span slot="title">
        --mcp-rune-local <span class="local-pathvar">&lt;path&gt;</span>
      </span>
      <span slot="right" class="local-rhint">for framework hackers</span>
    </CliSectionHeader>

    <div class="local-grid">
      <div class="local-copy-col">
        <p class="local-p">
          Pass a path to a local clone of <code>mcp-rune</code> and the scaffolder rewrites the
          dependency to <code>file:&lt;path&gt;</code> in <code>package.json</code>.
        </p>
        <p class="local-p">
          Now you can iterate on the framework and your project at the same time, in two
          windows, without publishing alphas. The intended workflow while we're pre-1.0.
        </p>

        <div class="local-when">
          <div class="local-when-eyebrow">WHEN TO USE IT</div>
          <ul class="local-when-list">
            {WHEN.map((b) => (
              <li class="local-when-item">
                <span class="local-arr">↳</span><span>{b}</span>
              </li>
            ))}
          </ul>
          <div class="local-when-foot">
            Day-to-day, drop the flag — your scaffold will resolve
            <code>@mcp-rune/mcp-rune</code> from the npm registry like a normal dependency.
          </div>
        </div>
      </div>

      <div class="local-terms">
        <div>
          <div class="local-eyebrow">WITHOUT --mcp-rune-local</div>
          <Terminal title="package.json · default" sub="resolves from npm"
><span class="t-dim">{`{
  "name": "my-server",
  "dependencies": {
    `}</span><span class="t-path">"@mcp-rune/mcp-rune"</span><span class="t-dim">: </span><span class="t-arg">"^0.1.0"</span><span class="t-dim">{`
  }
}`}</span></Terminal>
        </div>

        <div>
          <div class="local-eyebrow acc">WITH --mcp-rune-local ~/Code/mcp-rune</div>
          <Terminal title="package.json · local-linked" sub="resolves from disk"
><span class="t-dim">{`{
  "name": "my-server",
  "dependencies": {
    `}</span><span class="t-path">"@mcp-rune/mcp-rune"</span><span class="t-dim">: </span><span class="t-arg">"file:/Users/dsaenz/Code/mcp-rune"</span><span class="t-dim">{`
  }
}`}</span></Terminal>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cli-local { border-bottom: 1px solid var(--line); }
  .cli-local-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 64px 32px;
  }
  .local-pathvar { color: var(--ink-3); }
  .local-rhint {
    font-family: 'Geist Mono', monospace;
    font-size: 11.5px;
    color: var(--ink-4);
    white-space: nowrap;
  }

  .local-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 32px;
    align-items: flex-start;
  }

  .local-p {
    font-size: 15.5px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0 0 18px;
    max-width: 540px;
  }
  .local-p:last-of-type { margin-bottom: 0; }
  .local-p code {
    color: var(--acc-2);
    font-family: 'Geist Mono', monospace;
    font-size: 13px;
    background: transparent;
    border: none;
    padding: 0;
  }

  .local-when {
    margin-top: 28px;
    padding: 20px;
    border: 1px solid var(--line-2);
    border-radius: 10px;
    background: rgba(124, 92, 255, 0.04);
  }
  .local-when-eyebrow {
    font-family: 'Geist Mono', monospace;
    font-size: 10.5px;
    color: var(--acc-2);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .local-when-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .local-when-item {
    display: flex;
    gap: 10px;
    font-size: 13.5px;
    color: var(--ink-2);
    line-height: 1.55;
  }
  .local-arr { color: var(--acc-2); }
  .local-when-foot {
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px dashed var(--line-2);
    font-size: 12.5px;
    color: var(--ink-3);
    line-height: 1.6;
  }
  .local-when-foot code {
    color: var(--ink-2);
    background: var(--bg-3);
    padding: 1px 5px;
    border-radius: 3px;
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
  }

  .local-terms {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .local-eyebrow {
    font-family: 'Geist Mono', monospace;
    font-size: 10.5px;
    color: var(--ink-4);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .local-eyebrow.acc { color: var(--acc-2); }

  @media (max-width: 1024px) {
    .local-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .cli-local-inner { padding: 40px 16px; }
    .local-p { font-size: 14.5px; }
  }
</style>
