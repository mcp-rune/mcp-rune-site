---
---
<section class="cli-cta-band">
  <div class="cta-bg" aria-hidden="true" />
  <div class="cta-inner">
    <h2 class="pr-display cta-title">That's the whole CLI.</h2>
    <p class="cta-lede">
      The full reference — every flag, every prompt default, every
      generated file — lives in the docs.
    </p>
    <div class="cta-actions">
      <a class="pr-btn acc cta-btn" href="/docs/quickstart">
        Read the Quickstart <span class="arr">→</span>
      </a>
      <a class="pr-btn ghost cta-btn" href="/docs">
        All flags &amp; prompts <span class="arr">→</span>
      </a>
      <a
        class="pr-btn ghost cta-btn"
        href="https://github.com/mcp-rune/mcp-rune"
        target="_blank"
        rel="noopener noreferrer"
      >
        CLI source on GitHub <span class="arr">↗</span>
      </a>
    </div>
  </div>
</section>

<style>
  .cli-cta-band {
    position: relative;
    overflow: hidden;
  }
  .cta-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 60% at 50% 60%, rgba(124, 92, 255, 0.10), transparent 60%);
    pointer-events: none;
  }
  .cta-inner {
    position: relative;
    max-width: 1440px;
    margin: 0 auto;
    padding: 88px 32px 96px;
    text-align: center;
  }
  .cta-title {
    font-size: 48px;
    margin: 0;
    letter-spacing: -0.04em;
  }
  .cta-lede {
    font-size: 16px;
    color: var(--ink-3);
    max-width: 480px;
    margin: 18px auto 40px;
    line-height: 1.6;
  }
  .cta-actions {
    display: inline-flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .cta-btn {
    height: 44px;
    padding: 0 20px;
    font-size: 14px;
  }

  @media (max-width: 640px) {
    .cta-inner { padding: 64px 16px 72px; }
    .cta-title { font-size: 34px; }
    .cta-actions { flex-direction: column; align-items: stretch; width: 100%; }
  }
</style>
