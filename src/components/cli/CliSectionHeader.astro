---
interface Props {
  number: string;
  eyebrow: string;
  title: string;
  rightHint?: string;
}
const { number, eyebrow, title, rightHint } = Astro.props;
---
<div class="sec-head">
  <span class="sec-num">{number}. {eyebrow}</span>
  <h2 class="pr-display sec-title"><slot name="title">{title}</slot></h2>
  <span class="sec-rule" />
  <slot name="right">
    {rightHint && <span class="sec-rhint">{rightHint}</span>}
  </slot>
</div>

<style>
  .sec-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 24px;
  }
  .sec-num {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--acc-2);
    letter-spacing: 0.5px;
    white-space: nowrap;
  }
  .sec-title {
    font-size: 32px;
    margin: 0;
  }
  .sec-rule {
    flex: 1;
    height: 1px;
    background: var(--line);
  }
  .sec-rhint {
    font-family: 'Geist Mono', monospace;
    font-size: 11.5px;
    color: var(--ink-4);
    white-space: nowrap;
  }
  @media (max-width: 768px) {
    .sec-head { flex-wrap: wrap; gap: 10px; }
    .sec-title { font-size: 24px; }
    .sec-rule { display: none; }
    .sec-rhint { width: 100%; }
  }
</style>
