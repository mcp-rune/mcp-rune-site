---
// Landing v2 hero — outcome-first, pain-driven.
// Port of V2Hero in design's page-landing-v2.jsx. The book-example showcase
// that used to live here is now its own section (Showcase.astro); the
// founding-adopter callout moves to a later band. Branding lives in TopNav.

import { MCP_RUNE_VERSION_LABEL } from '../../data/version';
import { NPM_INSTALL } from '../../lib/site';
---
<section class="hero">
  <div class="hero-glow pr-glow"></div>
  <div class="hero-grid pr-grid-faint"></div>

  <div class="pr-wrap hero-top">
    <div class="hero-lockup">
      <img src="/brand/logo-horizontal-clean.svg" alt="mcp-rune" class="hero-lockup-img" />
    </div>

    <a href="/docs/mcp-apps" class="announce">
      <span class="badge-new">NEW</span>
      <span>{MCP_RUNE_VERSION_LABEL}-alpha · MCP Apps, OAuth 2.1, GraphRAG — all derived</span>
      <span class="announce-cta">Read →</span>
    </a>

    <h1 class="pr-display headline">
      Turn your data model into
      <span class="headline-grad">a complete MCP server.</span>
    </h1>

    <p class="lede">
      Every MCP integration starts the same way: hand-wiring route handlers, prompt templates,
      and auth flows for every model you ship.
      <span class="hi">
        Declare your schema once — mcp-rune derives the tools, prompts, OAuth, search, and
        interactive UI that agents need.
      </span>
    </p>

    <div class="cta-row">
      <a class="pr-btn acc cta-primary" href="/docs/quickstart">
        Get started <span class="arr">→</span>
      </a>
      <div class="install">
        <span class="install-prompt">$</span>
        <span class="pr-mono install-cmd">{NPM_INSTALL}</span>
        <button type="button" class="install-copy" data-copy={NPM_INSTALL}>COPY</button>
      </div>
    </div>

    <div class="meta-strip">
      <span>MIT <span class="meta-dim">— stays MIT</span></span>
      <span class="meta-bar"></span>
      <span>Node 20+ / Bun</span>
      <span class="meta-bar"></span>
      <span>TypeScript &amp; JavaScript</span>
      <span class="meta-bar"></span>
      <span>Zero external services</span>
      <span class="meta-bar"></span>
      <span class="meta-acc">Ship by lunch</span>
    </div>
  </div>
</section>

<style>
  .hero { position: relative; overflow: hidden; }
  .hero-glow { z-index: 0; }
  .hero-grid {
    position: absolute;
    inset: 0 0 30% 0;
    opacity: 0.6;
    z-index: 0;
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, black 30%, transparent 80%);
    mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, black 30%, transparent 80%);
  }
  .hero-top {
    position: relative;
    z-index: 1;
    padding: 88px 32px 56px;
    text-align: center;
  }

  .hero-lockup {
    display: flex;
    justify-content: center;
    margin-bottom: 40px;
  }
  .hero-lockup-img {
    display: inline-block;
    height: 88px;
    width: auto;
    flex-shrink: 0;
  }

  .announce {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(124, 92, 255, 0.07);
    border: 1px solid rgba(124, 92, 255, 0.25);
    padding: 5px 5px 5px 14px;
    border-radius: 999px;
    font-size: 13px;
    color: var(--ink-2);
    margin-bottom: 32px;
  }
  .badge-new {
    font-family: 'Geist Mono', monospace;
    font-size: 10.5px;
    color: var(--acc-2);
    letter-spacing: 0.5px;
  }
  .announce-cta {
    padding: 4px 10px;
    background: var(--ink);
    color: var(--bg);
    border-radius: 999px;
    font-size: 12px;
    font-weight: 500;
  }

  .headline {
    font-size: 84px;
    margin: 0;
    max-width: 980px;
    margin-left: auto;
    margin-right: auto;
  }
  .headline-grad {
    background-image: linear-gradient(180deg, #ffffff 0%, #a78bfa 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .lede {
    font-size: 19px;
    line-height: 1.55;
    color: var(--ink-3);
    margin: 28px auto 0;
    max-width: 680px;
    letter-spacing: -0.01em;
  }
  .lede .hi { color: var(--ink-2); }

  .cta-row {
    display: inline-flex;
    gap: 12px;
    margin-top: 36px;
    align-items: center;
  }
  .cta-primary { height: 44px; padding: 0 20px; font-size: 14px; }
  .install {
    height: 44px;
    display: inline-flex;
    align-items: stretch;
    background: var(--surface);
    border: 1px solid var(--line-2);
    border-radius: 8px;
    overflow: hidden;
  }
  .install-prompt {
    width: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--acc-2);
    font-family: 'Geist Mono', monospace;
    font-size: 14px;
    border-right: 1px solid var(--line-2);
    background: var(--bg-2);
  }
  .install-cmd {
    padding: 0 16px;
    font-size: 13.5px;
    align-self: center;
    color: var(--ink-2);
    white-space: nowrap;
  }
  .install-copy {
    border: none;
    border-left: 1px solid var(--line-2);
    background: transparent;
    padding: 0 14px;
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--ink-3);
    cursor: pointer;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }
  .install-copy:hover { color: var(--ink); }

  .meta-strip {
    margin-top: 28px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 24px;
    font-family: 'Geist Mono', monospace;
    font-size: 11.5px;
    color: var(--ink-4);
  }
  .meta-bar { width: 1px; height: 12px; background: var(--line-2); }
  .meta-dim { color: var(--ink-3); }
  .meta-acc { color: var(--acc-2); }

  @media (max-width: 768px) {
    .hero-top { padding: 36px 16px 28px; }
    .hero-lockup { margin-bottom: 28px; }
    .hero-lockup-img { height: 56px; }
    .announce { margin-bottom: 20px; font-size: 12px; padding: 4px 4px 4px 12px; }
    .headline { font-size: 44px; line-height: 1.02; }
    .lede { font-size: 16px; margin-top: 20px; }

    .cta-row {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 10px;
      width: 100%;
      margin-top: 28px;
    }
    .cta-primary { width: 100%; justify-content: center; height: 42px; }
    .install { width: 100%; }
    .install-cmd { flex: 1; }

    .meta-strip {
      margin-top: 22px;
      flex-wrap: wrap;
      gap: 10px 14px;
      justify-content: center;
    }
    .meta-bar { display: none; }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.install-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy ?? '';
      try {
        await navigator.clipboard.writeText(text);
        const original = btn.textContent;
        btn.textContent = 'COPIED';
        setTimeout(() => { btn.textContent = original; }, 1200);
      } catch {
        /* clipboard unavailable; do nothing */
      }
    });
  });
</script>
