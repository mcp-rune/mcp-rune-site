---
import Logo from '../Logo.astro';
---
<section class="close">
  <div class="close-glow"></div>
  <div class="pr-wrap close-inner">
    <h2 class="pr-display close-title">
      Ship a complete MCP server.<br />
      <span class="muted">By lunch.</span>
    </h2>
    <p class="close-lede">
      Scaffold a project, generate your first model, and run it locally in one terminal session.
      Auth, search, prompts, and apps all come along.
    </p>
    <div class="close-cta">
      <a class="pr-btn acc" href="/docs/mcp-apps" style="height: 44px; padding: 0 20px; font-size: 14px;">
        Read the quickstart <span class="arr">→</span>
      </a>
      <a class="pr-btn ghost" href="https://github.com/mcp-rune/mcp-rune" style="height: 44px; padding: 0 18px; font-size: 14px;">
        ★ Star on GitHub
      </a>
    </div>

    <div class="close-foot">
      <div class="close-foot-brand">
        <Logo size={22} />
        <span class="close-brand-name">mcp-rune</span>
        <span class="close-version">v0.1.0-alpha · MIT · 2026</span>
      </div>
      <div class="close-foot-links">
        {[
          { label: 'Docs', href: '/docs' },
          { label: 'CLI', href: '#' },
          { label: 'API', href: '#' },
          { label: 'Adopters', href: '#' },
          { label: 'GitHub', href: 'https://github.com/mcp-rune/mcp-rune' },
          { label: 'Roadmap', href: '/roadmap' },
        ].map(({ label, href }) => (
          <a href={href}>{label}</a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .close {
    position: relative;
    overflow: hidden;
  }
  .close-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 50% at 50% 60%, rgba(124, 92, 255, 0.14), transparent 60%);
    pointer-events: none;
  }
  .close-inner {
    position: relative;
    padding: 120px 32px 64px;
    text-align: center;
  }
  .close-title {
    font-size: 72px;
    margin: 0;
  }
  .muted { color: var(--ink-3); }
  .close-lede {
    font-size: 18px;
    color: var(--ink-3);
    margin: 24px auto 0;
    max-width: 560px;
  }
  .close-cta {
    display: inline-flex;
    gap: 12px;
    margin-top: 36px;
  }
  .close-foot {
    margin-top: 96px;
    padding-top: 32px;
    border-top: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .close-foot-brand {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .close-brand-name {
    font-family: 'Geist', sans-serif;
    font-weight: 500;
    font-size: 14px;
  }
  .close-version {
    font-family: 'Geist Mono', monospace;
    font-size: 11.5px;
    color: var(--ink-4);
    margin-left: 6px;
  }
  .close-foot-links {
    display: flex;
    gap: 28px;
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    color: var(--ink-3);
  }
  .close-foot-links a:hover { color: var(--ink); }

  @media (max-width: 768px) {
    .close-inner { padding: 72px 16px 48px; }
    .close-title { font-size: 40px; line-height: 1.05; }
    .close-lede { font-size: 16px; margin-top: 20px; }
    .close-cta {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 10px;
      width: 100%;
      margin-top: 28px;
    }
    .close-cta .pr-btn {
      width: 100%;
      justify-content: center;
    }
    .close-foot {
      flex-direction: column;
      gap: 16px;
      align-items: flex-start;
      margin-top: 56px;
    }
    .close-foot-links {
      flex-wrap: wrap;
      gap: 14px 18px;
    }
  }
</style>
