---
// Pain statement + before/after comparison.
// Port of V2Pain in design's page-landing-v2.jsx.

const rows: Array<[string, string]> = [
  ['10 models × 5 route handlers = 50 files',  '1 model definition per model'],
  ['Manual Zod schemas per route',             'Derived from attributes'],
  ['OAuth wiring from scratch',                'Built-in, spec-compliant OAuth 2.1'],
  ['Agent guesses your business rules',        'Encoded in DomainRegistry'],
  ['Tool list grows with every model',         'A fixed set of tools, regardless of model count'],
];
---
<section class="pain">
  <div class="pr-wrap pain-top">
    <div class="pain-statement">
      <div class="eyebrow">
        <span class="eyebrow-line"></span>
        <span>THE PROBLEM</span>
        <span class="eyebrow-line"></span>
      </div>
      <blockquote class="quote">
        Most MCP frameworks scale tool count with model count —
        <span class="hi">10 models × 5 verbs = 50 handlers</span>,
        a tool list that overflows the picker, and an LLM that struggles to choose.
      </blockquote>
      <p class="resolution">
        Add OAuth, prompt templates, and search — and you're maintaining hundreds of
        files that all say the same thing your schema already says.
      </p>
    </div>
  </div>

  <div class="pr-wrap pain-table-wrap">
    <div class="compare">
      <div class="col-head without">
        <span class="dot"></span>
        WITHOUT MCP-RUNE
      </div>
      <div class="col-head with">
        <span class="dot"></span>
        WITH MCP-RUNE
      </div>

      {rows.map(([without, withR], i) => (
        <>
          <div class:list={['row', 'without', { last: i === rows.length - 1 }]}>
            <span class="mark">✕</span>
            <span>{without}</span>
          </div>
          <div class:list={['row', 'with', { last: i === rows.length - 1 }]}>
            <span class="mark">✓</span>
            <span>{withR}</span>
          </div>
        </>
      ))}
    </div>
  </div>
</section>

<style>
  .pain {
    position: relative;
    border-top: 1px solid var(--line);
    background: linear-gradient(180deg, var(--bg-2) 0%, transparent 100%);
  }
  .pain-top { padding: 80px 32px 0; }
  .pain-statement { text-align: center; max-width: 800px; margin: 0 auto; }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--acc-2);
    font-family: 'Geist Mono', monospace;
    font-size: 11.5px;
    margin-bottom: 20px;
    letter-spacing: 0.4px;
  }
  .eyebrow-line { width: 16px; height: 1px; background: var(--acc); }

  .quote {
    font-family: 'Geist', sans-serif;
    font-size: 28px;
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.3;
    color: var(--ink);
    margin: 0 auto;
    max-width: 780px;
  }
  .quote .hi { color: var(--acc-2); }

  .resolution {
    font-size: 16px;
    color: var(--ink-3);
    margin: 20px auto 0;
    max-width: 580px;
    line-height: 1.6;
  }

  .pain-table-wrap { padding: 56px 32px 88px; }
  .compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid var(--line-2);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 30px 80px -40px rgba(0, 0, 0, 0.5);
  }

  .col-head {
    padding: 16px 24px;
    background: var(--bg-3);
    border-bottom: 1px solid var(--line-2);
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    color: var(--ink-3);
    letter-spacing: 0.3px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .col-head.without { border-right: 1px solid var(--line-2); }
  .col-head.with { color: var(--acc-2); }
  .col-head .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #f08a8a;
  }
  .col-head.with .dot { background: #7ee2c1; }

  .row {
    padding: 14px 24px;
    font-size: 14px;
    line-height: 1.5;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: 1px solid var(--line);
  }
  .row.last { border-bottom: none; }
  .row.without {
    background: var(--surface);
    color: var(--ink-3);
    border-right: 1px solid var(--line-2);
  }
  .row.with {
    background: rgba(124, 92, 255, 0.03);
    color: var(--ink);
  }
  .row .mark {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    flex-shrink: 0;
  }
  .row.without .mark { color: #f08a8a; }
  .row.with .mark { color: #7ee2c1; }

  @media (max-width: 768px) {
    .pain-top { padding: 56px 16px 0; }
    .pain-table-wrap { padding: 36px 16px 56px; }
    .quote { font-size: 20px; }
    .resolution { font-size: 14px; }
    .compare { grid-template-columns: 1fr; }
    .col-head.without {
      border-right: none;
      border-bottom: 1px solid var(--line-2);
    }
    .row.without {
      border-right: none;
      border-bottom: 1px solid var(--line);
    }
    .row { padding: 12px 16px; font-size: 13px; }
    .col-head { padding: 12px 16px; }
  }
</style>
