---
import Logo from './Logo.astro';
import RuneContactStrip from './RuneContactStrip.astro';
import { MCP_RUNE_VERSION_LABEL, SITE_VERSION_LABEL } from '../data/version';

const columns: Array<{ heading: string; items: string[] }> = [
  { heading: 'Framework', items: ['Models', 'Prompt DSL', 'Tools', 'MCP Apps', 'Analysis'] },
  { heading: 'Tooling',   items: ['CLI', 'Generators', 'Inspector', 'Types'] },
  { heading: 'Learn',     items: ['Quickstart', 'Guides', 'Architecture', 'Recipes'] },
  { heading: 'Community', items: ['Adopter charter', 'GitHub', 'Discussions', 'RFCs'] },
];
---
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div>
        <div class="footer-brand">
          <Logo size={22} />
          <span class="footer-brand-name">mcp-rune</span>
        </div>
        <p class="footer-tagline">
          A model‑driven framework for production MCP servers. Forged from <span class="hl">mcp-kit</span>.
        </p>
      </div>
      {columns.map(({ heading, items }) => (
        <details class="footer-col">
          <summary class="footer-heading">
            {heading}
            <span class="chev">▾</span>
          </summary>
          <ul class="footer-list">
            {items.map((item) => (
              <li><a href="#">{item}</a></li>
            ))}
          </ul>
        </details>
      ))}
    </div>
    <RuneContactStrip />
    <div class="footer-bottom">
      <span>© 2026 · mcp-rune · MIT</span>
      <span>{MCP_RUNE_VERSION_LABEL} framework · site {SITE_VERSION_LABEL}</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    background: var(--bg-2);
  }
  .footer-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 40px 32px 28px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 32px;
    border-bottom: 1px dashed var(--line-2);
  }
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .footer-brand-name {
    font-family: 'Geist', sans-serif;
    font-weight: 500;
    font-size: 14px;
  }
  .footer-tagline {
    font-size: 13px;
    color: var(--ink-3);
    max-width: 280px;
    line-height: 1.55;
    margin: 0;
  }
  .footer-tagline .hl { color: var(--ink-2); }
  .footer-heading {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--ink-4);
    letter-spacing: 0.4px;
    margin-bottom: 12px;
    text-transform: uppercase;
  }
  .footer-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer-list a {
    font-size: 13px;
    color: var(--ink-2);
  }
  .footer-list a:hover { color: var(--ink); }
  .footer-bottom {
    padding-top: 20px;
    display: flex;
    justify-content: space-between;
    font-family: 'Geist Mono', monospace;
    font-size: 11.5px;
    color: var(--ink-4);
  }

  /* Desktop: <details> renders as plain expanded columns */
  .footer-col > summary {
    list-style: none;
    cursor: default;
    pointer-events: none;
  }
  .footer-col > summary::-webkit-details-marker { display: none; }
  .footer-col .chev { display: none; }
  .footer-col > .footer-list { display: flex !important; }

  @media (max-width: 768px) {
    .footer-inner { padding: 32px 16px 28px; }
    .footer-grid {
      display: flex;
      flex-direction: column;
      gap: 0;
      padding-bottom: 16px;
    }
    .footer-col > summary {
      pointer-events: auto;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 0;
      margin-bottom: 0;
      border-top: 1px solid var(--line);
    }
    .footer-col .chev {
      display: inline;
      color: var(--ink-5);
      transition: transform 120ms;
    }
    .footer-col[open] .chev { transform: rotate(180deg); }
    .footer-col:not([open]) > .footer-list { display: none !important; }
    .footer-col[open] > .footer-list { padding: 0 4px 14px; }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 6px;
    }
  }
</style>
