---
import Logo from './Logo.astro';

interface Props {
  active?: 'docs' | 'ref' | 'cli' | 'adopt' | 'roadmap' | null;
  /** Wider container for the docs-section pages (1440px), narrower for landing (1240px). */
  wide?: boolean;
}
const { active = null, wide = false } = Astro.props;

const links: Array<{ label: string; key: NonNullable<Props['active']>; href: string }> = [
  { label: 'Docs',      key: 'docs',  href: '/docs' },
  { label: 'Reference', key: 'ref',   href: '#' },
  { label: 'CLI',       key: 'cli',   href: '#' },
  { label: 'Adopters',  key: 'adopt', href: '#' },
  { label: 'Roadmap',   key: 'roadmap', href: '/roadmap' },
];
---
<header class="topnav">
  <div class="topnav-inner" style={wide ? 'max-width: 1440px;' : 'max-width: 1240px;'}>
    <a href="/" class="brand">
      <Logo size={24} />
      <span class="brand-name">mcp-rune</span>
      <span class="version">0.1.0</span>
    </a>
    <nav class="links">
      {links.map(({ label, key, href }) => (
        <a href={href} class:list={['nav-link', { on: key === active }]}>{label}</a>
      ))}
    </nav>
    <div class="search">
      <span>⌕</span>
      <span class="search-label">Search docs</span>
      <span class="flex-spacer" />
      <span class="kbd">⌘K</span>
    </div>
    <div class="actions">
      <a class="pr-btn ghost compact" href="https://github.com/mcp-rune/mcp-rune">
        <span class="star">★</span>
        <span>1,243</span>
      </a>
      <a class="pr-btn compact" href="/docs/quickstart">
        Get started <span class="arr">→</span>
      </a>
    </div>

    <div class="topnav-mobile">
      <button type="button" class="icon-btn search-btn" aria-label="Search">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.4" />
          <path d="M11 11l3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
        </svg>
      </button>
      <button type="button" class="icon-btn menu-btn" id="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="nav-drawer">
        <span class="bar" /><span class="bar" />
      </button>
    </div>
  </div>

  <div id="nav-drawer" class="mobile-drawer" hidden>
    {links.map(({ label, key, href }) => (
      <a href={href} class:list={['drawer-link', { on: key === active }]}>
        {label}
        <span class="drawer-arr">↗</span>
      </a>
    ))}
    <div class="drawer-cta">
      <a class="pr-btn ghost" href="https://github.com/mcp-rune/mcp-rune">
        <span class="star">★</span><span>GitHub · 1,243</span>
      </a>
      <a class="pr-btn" href="/docs/quickstart">
        Get started <span class="arr">→</span>
      </a>
    </div>
  </div>
</header>

<style>
  .topnav {
    position: sticky;
    top: 0;
    z-index: 30;
    backdrop-filter: blur(12px);
    background: rgba(7, 7, 10, 0.75);
    border-bottom: 1px solid var(--line);
  }
  .topnav-inner {
    margin: 0 auto;
    padding: 0 32px;
    height: 60px;
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .brand-name {
    font-family: 'Geist', sans-serif;
    font-weight: 500;
    font-size: 15px;
    letter-spacing: -0.01em;
  }
  .version {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--ink-3);
    padding: 2px 6px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 4px;
  }
  .links {
    display: flex;
    gap: 4px;
    flex: 1;
  }
  .nav-link {
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 13.5px;
    font-weight: 450;
    color: var(--ink-3);
    background: transparent;
    border: 1px solid transparent;
  }
  .nav-link.on {
    color: var(--ink);
    background: var(--surface);
    border-color: var(--line);
  }
  .search {
    height: 32px;
    width: 240px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 10px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 6px;
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    color: var(--ink-3);
    white-space: nowrap;
  }
  .search-label { color: var(--ink-2); }
  .flex-spacer { flex: 1; }
  .kbd {
    font-family: 'Geist Mono', monospace;
    font-size: 10.5px;
    padding: 2px 5px;
    background: var(--bg);
    border: 1px solid var(--line-2);
    border-radius: 3px;
    color: var(--ink-3);
    flex-shrink: 0;
  }
  .actions {
    display: flex;
    gap: 8px;
  }
  .pr-btn.compact { height: 32px; padding: 0 12px; font-size: 13px; }
  .star { color: var(--ink-3); }

  /* mobile chrome — hidden by default */
  .topnav-mobile { display: none; }
  .icon-btn {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: transparent;
    border: 1px solid var(--line);
    color: var(--ink-2);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  .icon-btn.menu-btn {
    background: var(--surface);
    color: var(--ink);
    flex-direction: column;
    gap: 4px;
  }
  .icon-btn.menu-btn .bar {
    width: 14px;
    height: 1.5px;
    background: currentColor;
    border-radius: 1px;
  }
  .mobile-drawer { display: none; }
  .mobile-drawer.open {
    display: flex;
    flex-direction: column;
    position: absolute;
    top: 60px;
    left: 0;
    right: 0;
    z-index: 40;
    background: rgba(7, 7, 10, 0.96);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--line);
    padding: 8px 16px 16px;
  }
  .drawer-link {
    display: flex;
    align-items: center;
    padding: 12px 8px;
    font-family: 'Geist', sans-serif;
    font-size: 15px;
    color: var(--ink);
    border-bottom: 1px solid var(--line);
  }
  .drawer-link.on { color: var(--acc-2); }
  .drawer-arr {
    margin-left: auto;
    color: var(--ink-4);
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
  }
  .drawer-cta {
    display: flex;
    gap: 8px;
    margin-top: 14px;
  }
  .drawer-cta .pr-btn {
    flex: 1;
    height: 38px;
    font-size: 13px;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .topnav-inner {
      height: 52px;
      padding: 0 16px;
      gap: 10px;
    }
    .links,
    .search,
    .actions { display: none; }
    .topnav-mobile {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-left: auto;
    }
    .mobile-drawer.open { top: 52px; }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const drawer = document.getElementById('nav-drawer');

  function setDrawer(open: boolean) {
    if (!drawer || !toggle) return;
    drawer.classList.toggle('open', open);
    if (open) {
      drawer.removeAttribute('hidden');
    } else {
      drawer.setAttribute('hidden', '');
    }
    toggle.setAttribute('aria-expanded', String(open));
  }

  toggle?.addEventListener('click', () => {
    setDrawer(!drawer?.classList.contains('open'));
  });

  drawer?.querySelectorAll<HTMLAnchorElement>('a').forEach((a) => {
    a.addEventListener('click', () => setDrawer(false));
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth > 768) setDrawer(false);
  });
</script>
