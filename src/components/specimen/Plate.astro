---
/**
 * Plate — framed specimen card for the /components catalog.
 * Corner ticks + plate number + name + category + stage slot + spec footer.
 */

interface Props {
  no: string;
  name: string;
  cat: string;
  /** Width in grid columns. Default 1. */
  span?: number;
}

const { no, name, cat, span = 1 } = Astro.props;
const styleAttr = span > 1 ? `grid-column: span ${span};` : undefined;
---
<section class="plate" style={styleAttr}>
  <div class="plate-head">
    <span class="plate-no">{no}</span>
    <span class="plate-name">{name}</span>
    <span class="plate-cat">{cat}</span>
  </div>
  <div class="plate-stage">
    <span class="tick tl" /><span class="tick tr" />
    <span class="tick bl" /><span class="tick br" />
    <slot />
  </div>
  <div class="plate-spec">
    <slot name="spec" />
  </div>
</section>

<style>
  .plate {
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    background: var(--bg-2);
    display: flex;
    flex-direction: column;
  }
  .plate-head {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--line);
  }
  .plate-no {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--acc-2);
    letter-spacing: 0.4px;
  }
  .plate-name {
    font-family: 'Geist', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .plate-cat {
    margin-left: auto;
    font-family: 'Geist Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: var(--ink-4);
  }
  .plate-stage {
    position: relative;
    flex: 1;
    min-height: 132px;
    padding: 26px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.035) 1px, transparent 1.2px);
    background-size: 16px 16px;
  }
  .plate-spec {
    padding: 11px 16px;
    border-top: 1px solid var(--line);
    font-size: 12px;
    color: var(--ink-3);
    line-height: 1.5;
    background: var(--bg-2);
  }
  .plate-spec :global(code) {
    font-family: 'Geist Mono', monospace;
    font-size: 0.86em;
    color: var(--ink-2);
    background: var(--bg-3);
    border: 1px solid var(--line-2);
    padding: 1px 5px;
    border-radius: 4px;
  }

  .tick {
    position: absolute;
    width: 8px;
    height: 8px;
    opacity: 0.5;
  }
  .tick::before,
  .tick::after {
    content: '';
    position: absolute;
    background: var(--line-3);
  }
  .tick::before { width: 8px; height: 1px; top: 0; }
  .tick::after { width: 1px; height: 8px; left: 0; }
  .tick.tl { top: 8px; left: 8px; }
  .tick.tr { top: 8px; right: 8px; transform: scaleX(-1); }
  .tick.bl { bottom: 8px; left: 8px; transform: scaleY(-1); }
  .tick.br { bottom: 8px; right: 8px; transform: scale(-1); }
</style>
